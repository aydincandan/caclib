{
  "name": "caclib",
  "version": "1.1.11",
  "description": "kullanımlar :  caclib | ( /hellpers , /argshellper , /cevapbekle , /zgraupner , /nextanother )        My Dual Module Library : https://chatgpt.com/share/68124b0c-5ea0-8011-8476-a13d1120ad41",
  "main": "./cevapbekle/cjs/index.cjs",
  "scripts": {
    "update-outdated-packages": "npx npm-check-updates -u && npm install",
    "build:types": "tsc -p tsconfig.build.json",
    "build:copy": "node ./scripts/copy.mjs",
    "build-": "npm run build:types && npm run build:copy",
    "build": "npm run build:types && node scripts/fix-types.mjs && npm run build:copy"
  },
  "exports": {
    ".": {
      "types": "./dist/hellpers/index.d.ts",
      "require": "./hellpers/cjs/index.cjs",
      "import": "./hellpers/esm/index.js"
    },
    "./hellpers": {
      "types": "./dist/argshellper/index.d.ts",
      "require": "./hellpers/cjs/index.cjs",
      "import": "./hellpers/esm/index.js"
    },
    "./argshellper": {
      "require": "./argshellper/cjs/argsHelperV3.cjs",
      "import": "./argshellper/esm/argsHelperV4.js"
    },
    "./cevapbekle": {
      "require": "./cevapbekle/cjs/index.cjs",
      "import": "./cevapbekle/esm/indexESM.js"
    },
    "./zgraupner": {
      "require": "./zgraupner/cjs/index.cjs",
      "import": "./zgraupner/esm/indexESM.js"
    },
    "./nextanother": {
      "require": "./nextanother/cjs/index.cjs",
      "import": "./nextanother/esm/indexESM.js"
    }
  },
  "files": [
    "cevapbekle",
    "zgraupner",
    "argshellper",
    "hellpers",
    "nextanother",
    "README.md"
  ],
  "keywords": [
    "library",
    "dual",
    "esm",
    "commonjs"
  ],
  "license": "ISC",
  "author": "Aydin Candan <aydincandan@gmail.com>",
  "dependencies": {
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}